# SDDP Docker Compose Environment Variables
# Copy this file to .env and customize for your environment.

# PostgreSQL Database Credentials
POSTGRES_USER=sddp
POSTGRES_PASSWORD=sddp_password
POSTGRES_DB=sddp

# Git Integration (optional)
# SDDP_GIT__TOKEN=
# SDDP_GIT__USERNAME=
# SDDP_GIT__REPOROOT=
