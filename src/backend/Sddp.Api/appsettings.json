{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=sddp_db;Username=sddp_user;Password=change_me_in_production"
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_TO_A_SECURE_SECRET_KEY_AT_LEAST_32_CHARACTERS",
    "Issuer": "sddp-api",
    "Audience": "sddp-client",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3500",
      "http://localhost:5173",
      "http://localhost:9010"
    ]
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "sddp:"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "Git": {
    "RepoRoot": "data/git-repos",
    "Username": "oauth2"
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317"
  },
  "FeatureFlags": {
    "Artifacts": {
      "MaintenanceEnabled": false,
      "MaintenanceDisabledMessage": "Artifact maintenance actions are coming soon. This environment currently limits regenerate and bulk verify operations."
    },
    "SystemConfig": {
      "AuthenticationEnabled": false,
      "AuthenticationDisabledMessage": "Authentication settings are coming soon. Runtime integration is not enabled in this environment.",
      "PerformanceEnabled": false,
      "PerformanceDisabledMessage": "Performance settings are coming soon. Runtime integration is not enabled in this environment."
    }
  }
}
