{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@sddp/ui": ["../ui/src"],
      "@sddp/ui/*": ["../ui/src/*"],
      "@sddp/shell": ["../shell/src"],
      "@sddp/shell/*": ["../shell/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "**/__tests__/**"]
}
