{
  "name": "@sddp/ui",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "svelte": "./src/index.ts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./controls": {
      "svelte": "./src/controls/index.ts",
      "types": "./dist/controls/index.d.ts",
      "default": "./dist/controls/index.js"
    },
    "./control": {
      "svelte": "./src/controls/index.ts",
      "types": "./dist/controls/index.d.ts",
      "default": "./dist/controls/index.js"
    },
    "./types": {
      "svelte": "./src/types/index.ts",
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./styles": "./src/styles/design-tokens.css"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "svelte-package -i src -o dist",
    "type-check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src --ext .ts,.svelte",
    "lint:fix": "eslint src --ext .ts,.svelte --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.5.0",
    "@storybook/addon-essentials": "^8.5.0",
    "@storybook/addon-interactions": "^8.5.0",
    "@storybook/svelte": "^8.5.0",
    "@storybook/svelte-vite": "^8.5.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.0.0",
    "storybook": "^8.5.0",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@internationalized/date": "^3.10.1",
    "bits-ui": "^2.15.5"
  }
}
