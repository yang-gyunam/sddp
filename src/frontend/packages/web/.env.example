# SDDP Frontend Environment Variables
# Copy this file to .env and customize for your environment

# API Configuration
VITE_API_URL=http://localhost:5001
VITE_API_VERSION=v1

# Feature Flags
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_AI_FEATURES=false
VITE_ENABLE_ARTIFACT_MAINTENANCE=false
VITE_ENABLE_PROJECT_INTEGRATIONS=false
VITE_ENABLE_SPEC_SUPPLEMENTARY_TABS=false
VITE_ENABLE_SYSTEM_CONFIG_AUTHENTICATION=false
VITE_ENABLE_SYSTEM_CONFIG_PERFORMANCE=false
VITE_ENABLE_RUNES_TOAST_STORE=false
VITE_ENABLE_RUNES_PANEL_STORE=false
VITE_ENABLE_RUNES_TAB_STATE_STORE=false
VITE_ENABLE_RUNES_COMMAND_STORE=false
VITE_ENABLE_RUNES_MENU_STORE=false
VITE_ENABLE_RUNES_SIDE_PANEL_STORE=false
VITE_ENABLE_RUNES_PANEL_CONTENT_STORE=false
VITE_ENABLE_RUNES_TABS_STORE=false
VITE_ENABLE_RUNES_STORE_SHADOW_PARITY=true

# Authentication
VITE_AUTH_TOKEN_EXPIRY=900  # 15 minutes in seconds
