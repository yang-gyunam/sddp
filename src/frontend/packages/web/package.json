{
  "name": "@sddp/web",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "type-check": "svelte-check --tsconfig ./tsconfig.app.json",
    "lint": "eslint . --ext .ts,.svelte",
    "lint:fix": "eslint . --ext .ts,.svelte --fix",
    "format": "prettier --write \"src/**/*.{ts,svelte,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,svelte,css,html}\"",
    "test": "vitest --config vitest.unit.config.ts",
    "test:unit": "vitest --config vitest.unit.config.ts",
    "test:unit:coverage": "vitest --config vitest.unit.config.ts --coverage",
    "test:coverage": "vitest --config vitest.unit.config.ts --coverage",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "test:integration:coverage": "vitest --config vitest.integration.config.ts --coverage",
    "test:e2e": "playwright test --config=playwright.showcase.config.ts",
    "test:e2e:ui": "playwright test --ui --config=playwright.showcase.config.ts",
    "test:e2e:L0": "playwright test L0/",
    "test:e2e:L1": "playwright test L1/",
    "test:e2e:L2": "playwright test L2/",
    "test:e2e:L3": "playwright test L3/",
    "test:e2e:showcase": "playwright test --config=playwright.showcase.config.ts",
    "test:e2e:showcase:onbrick": "playwright test --config=playwright.showcase.config.ts S/S2-onbrick",
    "test:e2e:dashboard": "HEADED=1 playwright test",
    "test:e2e:showcase:all": "./scripts/run-e2e-showcase.sh",
    "test:e2e:story": "playwright test S/S2-onbrick"
  },
  "dependencies": {
    "@sddp/activities": "*",
    "@sddp/shell": "*",
    "@sddp/ui": "*",
    "svelte-spa-router": "^4.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitest/coverage-v8": "^4.0.17",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.0.0",
    "msw": "^2.12.10",
    "postcss": "^8.5.6",
    "prettier": "^3.8.0",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.2.4",
    "vitest": "^4.0.17"
  }
}
