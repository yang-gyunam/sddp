{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "types": ["svelte", "vite/client"],
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "allowJs": true,
    "checkJs": true,
    "moduleDetection": "force",
    "baseUrl": ".",
    "paths": {
      "@sddp/ui": ["../ui/src"],
      "@sddp/ui/*": ["../ui/src/*"],
      "@sddp/shell": ["../shell/src"],
      "@sddp/shell/*": ["../shell/src/*"],
      "@sddp/activities": ["../activities/src"],
      "@sddp/activities/*": ["../activities/src/*"],
      "$lib": ["src/lib"],
      "$lib/*": ["src/lib/*"],
      "$stores": ["src/stores"],
      "$stores/*": ["src/stores/*"],
      "$types": ["src/types"],
      "$types/*": ["src/types/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**"
  ]
}
